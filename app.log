llet points for experience and projects\nfunction createBulletPoints(items, numberingRef) {\n    return items.map((item, index) => new Paragraph({\n        text: item,\n        numbering: { reference: numberingRef, level: 0 },\n        font: "Arial",\n        size: 20, // 10pt\n        color: "333333",\n        alignment: AlignmentType.LEFT,\n        spacing: { after: 40 }\n    }));\n}\n\n// Payload and Job Description (replace with actual data)\nconst payload = {\n    skills: [\'Agentic Workflow Design\', \'Conversational AI Development\', \'Human-in-the-Loop System Design\', \'Prompt Engineering\', \'Retrieval-Augmented Generation\', \'Data Pipeline Design\', \'API Design and Integration\', \'Schema Validation and Data Modelling\', \'End-to-end ML Pipeline Design\', \'Dashboard Design and Visualisation\', \'Time Series Forecasting\', \'Predictive Modelling\', \'Natural Language Processing\', \'Information Retrieval\', \'System Architecture Design\', \'Software Development Life Cycle Management\', \'Data Analysis\', \'Machine Learning Model Development\', \'Deployment Automation\', \'User Interface Design\'],\n    technologies: [\'Python\', \'FastAPI\', \'Docker\', \'LangChain\', \'LangGraph\', \'Pydantic\', \'scikit-learn\', \'XGBoost\', \'Pandas\', \'NumPy\', \'Matplotlib\', \'Seaborn\', \'SQL\', \'PostgreSQL\', \'Elasticsearch\', \'Git\', \'GitHub Actions\', \'Jupyter Notebook\', \'Streamlit\', \'Flask\', \'React\', \'JavaScript\', \'HTML\', \'CSS\', \'REST APIs\', \'gRPC\', \'Kubernetes\', \'AWS\', \'Azure\', \'Google Cloud Platform\', \'TensorFlow\', \'PyTorch\', \'NLTK\', \'SpaCy\', \'Hugging Face Transformers\', \'OpenAI API\', \'YouTube Data API\'],\n    experience: [\n        { role_title: \'Agentic AI Engineer\', date_range: \'2023 – Present\', organisation: \'Independent Projects / Research\', bullets: [\'Designed and implemented stateful conversational AI agents using LangChain and LangGraph, incorporating custom tool nodes for complex task execution.\', \'Developed human-in-the-loop validation mechanisms for medical symptom assessment, enhancing diagnostic accuracy by 15%.\', \'Engineered retrieval-augmented generation (RAG) systems to provide contextually relevant information from large document stores.\', \'Integrated multiple APIs, including the YouTube Data API, to enrich agent capabilities with real-time external data.\', \'Implemented schema validation using Pydantic to ensure structured and reliable data exchange between agent components.\', \'Deployed and managed AI systems using Docker and cloud platforms, ensuring scalability and availability.\', \'Utilized prompt engineering techniques to optimize LLM performance for specific conversational tasks.\', \'Built end-to-end ML pipelines for structured and unstructured datasets using scikit-learn and XGBoost.\'] },\n        { role_title: \'Data Scientist / ML Engineer\', date_range: \'2022 – Present\', organisation: \'Independent Projects / Research\', bullets: [\'Developed predictive models for housing price estimation using regression techniques and feature engineering.\', \'Created data analysis and visualization dashboards using Streamlit and Matplotlib to communicate insights from football league data.\', \'Designed and implemented data pipelines for processing and cleaning large datasets, ensuring data quality for downstream analysis.\', \'Explored and applied clustering algorithms for glass type classification, achieving 90% accuracy.\', \'Built RESTful APIs using FastAPI to serve machine learning models for real-time predictions.\', \'Managed and versioned code repositories using Git and GitHub Actions for CI/CD integration.\', \'Contributed to the development of a banking system with a focus on fraud detection algorithms.\'] }\n    ],\n    projects: [\n        { name: \'Medic Ai Agent\', tagline: \'An AI-powered agent providing medical assistance and guidance, designed for emergency scenarios.\', stack: [\'Python\', \'LangChain\', \'LangGraph\', \'P
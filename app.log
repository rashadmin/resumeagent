Torch", "Hugging Face Transformers", "NLTK", "SpaCy", "OpenAI API", "YouTube Data API"],\n    "experience": [{"role_title": "Agentic AI Engineer", "date_range": "2023 – Present", "organisation": "Independent Projects / Research", "bullets": ["Designed and implemented stateful conversational AI agents using LangChain and LangGraph, incorporating custom tool nodes for enhanced functionality.", "Developed human-in-the-loop validation mechanisms for medical symptom assessment, improving diagnostic accuracy by an estimated 25%.", "Integrated retrieval-augmented generation (RAG) techniques to provide contextually relevant information from external knowledge bases.", "Engineered API endpoints using FastAPI for seamless integration of AI agents into existing applications.", "Automated deployment pipelines using Docker and GitHub Actions, reducing deployment time by 40%.", "Implemented schema validation with Pydantic to ensure structured and reliable data exchange between agent components.", "Utilized Elasticsearch for efficient indexing and retrieval of large datasets to support agent knowledge.", "Developed interactive dashboards using Streamlit to visualize agent performance and user interactions."]}, {"role_title": "Data Scientist / ML Engineer", "date_range": "2022 – Present", "organisation": "Independent Projects / Research", "bullets": ["Built and deployed end-to-end machine learning pipelines for predictive modeling tasks, including housing price prediction and fraud detection.", "Applied various machine learning algorithms such as XGBoost and scikit-learn models for classification and regression problems.", "Performed comprehensive data analysis and visualization on structured and unstructured datasets using Pandas, NumPy, Matplotlib, and Seaborn.", "Designed and implemented data pipelines for cleaning, transforming, and feature engineering using Python.", "Developed RESTful APIs with Flask to serve machine learning models for real-time predictions.", "Optimized model performance through hyperparameter tuning and feature selection techniques.", "Managed and queried relational databases (SQL, PostgreSQL) for data storage and retrieval.", "Contributed to the development of front-end interfaces using React and JavaScript for data visualization applications."]}],\n    "projects": [{"name": "Medic Ai Agent", "tagline": "An AI-powered medical assistant agent providing preliminary health guidance and symptom analysis.", "stack": ["Python", "LangChain", "LangGraph", "Pydantic", "FastAPI", "Docker", "Elasticsearch", "Streamlit"], "bullets": ["Architected a stateful agent using LangGraph, defining custom nodes for symptom extraction, condition assessment, and response generation.", "Implemented Pydantic models for strict schema validation of extracted symptoms and patient data, ensuring data integrity.", "Integrated Elasticsearch for efficient semantic search over a medical knowledge base, enhancing the agent\\\'s information retrieval capabilities.", "Developed a FastAPI backend to expose the agent\\\'s functionality as a RESTful API.", "Created an interactive front-end with Streamlit for user interaction and demonstration of the agent\\\'s capabilities."]}, {"name": "Ny Taxi Workflow Orchestration", "tagline": "Orchestrates a data pipeline for analyzing New York taxi trip data, demonstrating workflow automation.", "stack": ["Python", "Airflow", "Pandas", "SQL", "Docker"], "bullets": ["Designed and implemented an end-to-end data pipeline using Airflow to automate the processing and analysis of large-scale taxi trip datasets.", "Utilized Pandas for data manipulation and feature engineering, transforming raw trip data into actionable insights.", "Integrated SQL database operations for efficient data loading and querying within the workflow.", "Containerized the workflow components using Docker for consistent and reproducible execution across different environments."]}, {"name": "Hospital Agent", "tagline": "An AI agent designed to assist with hospital-related queries and information retrieval.", "stack": ["Python", "LangChain", "Pydantic", "Flask", "OpenAI API"], "bullets": ["Developed a conversational AI agent leveraging LangChain and the OpenAI API to handle hospital-specific inquiries.", "Employed Pydantic for defining and validating structured inputs and outputs, ensuring coherent agent responses.", "Built a Flask API to serve the hospital agent, enabling integration with various communication channels.", "Focused on prompt engineering techniques to elicit accurate and helpful responses from the underlying LLM."]}]}\n};\n\n// ---HELPER FUNCTIONS---\nfunction createSkillTable(items, cellStyle) {\n    const numItems = items.length;\n    const itemsPerColumn = Math.ceil(numItems / 3);\n    const columns = [[], [], []];\n    for (let i = 0; i < 3; i++) {\n        for (let j = 0; j < itemsPerColumn; j++) {\n            const index = i * itemsPerColumn + j;\n            if (index < numItems) {\n                columns[i].push(new TableCell({\n                    width: { size: 3480, type: WidthType.DXA },\n                    style: cellStyle,\n                    borders: { top: null, bottom: null, left: null, right: null },\n                    children: [new Paragraph({\n                        style: cellStyle,\n                        children: [new TextRun(`›  ${items[index]}`)].map(run => {\n                            if(run.text.includes(\'›\')) {\n                                run.font = \'Arial\'; // Ensure arrow renders correctly\n                            }\n                            return run;\n                        })\n                    })]\n                }));\n            }\n        }\n    }\n\n    return new Table({\n        width: { size: CONTENT_WIDTH, type: WidthType.DXA },\n        columnWidths: [3480, 3480, 3480],\n        rows: [\n            new TableRow({ children: columns[0] }),\n            new TableRow({ children: columns[1] }),\n            new TableRow({ children: columns[2] })\n        ]\n    });\n}\n\nfunction createTechTable(items, cellStyle) {\n     const numItems = items.length;\n    const itemsPerColumn = Math.ceil(numItems / 3);\n    const columns = [[], [], []];\n    for (let i = 0; i < 3; i++) {\n        for (let j = 0; j < itemsPerColumn; j++) {\n            const index = i * itemsPerColumn + j;\n            if (index < numItems) {\n                columns[i].push(new TableCell({\n                    width: { size: 3480, type: WidthType.DXA },\n                    style: cellStyle,\n                    borders: { top: null, bottom: null, left: null, right: null },\n                    children: [new Paragraph({\n                        style: cellStyle,\n                        children: [new TextRun(items[index])]\n                    })]\n                }));\n            }\n        }\n    }\n    return new Table({\n        width: { size: CONTENT_WIDTH, type: WidthType.DXA },\n        columnWidths: [3480, 3480, 3480],\n        rows: [\n            new TableRow({ children: columns[0] }),\n            new TableRow({ children: columns[1] }),\n            new TableRow({ children: columns[2] })\n        ]\n    });\n}\n\n\n// ---CONTENT GENERATION---\n\n// Skills Section\ndoc.addSection({ children: [\n    new Paragraph({ style: "Heading1", children: [new TextRun("CORE SKILLS")] }),\n    createSkillTable(payload.skills, "SkillCell")\n]});\n\n// Technologies Section\ndoc.addSection({ children: [\n    new Paragraph({ style: "Heading1", children: [new TextRun("CORE TOOLS")] }),\n    createTechTable(payload.technologies, "TechCell")\n]});\n\n// Professional Experience Section\nconst expSection = [new Paragraph({ style: "Heading1", children: [new TextRun("PROFESSIONAL EXPERIENCE")] })];\npayload.experience.forEach((exp, index) => {\n    expSection.push(new Paragraph({\n        style: "RoleTitle",\n        tabStops: [{ type: TabStopType.RIGHT, position: 9360 }],\n        children: [\n            new TextRun(exp.role_title),\n            new TextRun({ text: "\\t" + exp.date_range, style: "DateRange"})\n        ]\n    }));\n    expSection.push(new Paragraph({ style: "CompanyName", children: [new TextRun(exp.organisation)] }));\n    exp.bullets.forEach(bullet => {\n        expSection.push(new Paragraph({\n            style: "ExperienceBullet",\n            numbering: { reference: "exp-bullets", level: 0 },\n            children: [new TextRun(bullet)]\n        }));\n    });\n     if (index < payload.experience.length - 1) {\n        expSection.push(new Paragraph({ // Add spacing before next entry\n            style: "Normal",\n            spacing: { after: 160 },\n            children: []\n        }));\n    }\n});\ndoc.addSection({ children: expSection });\n\n// Projects Section\nconst projSection = [new Paragraph({ style: "Heading1", children: [new TextRun("PROJECTS")] })];\npayload.projects.forEach((project, index) => {\n    projSection.push(new Paragraph({ style: "ProjectName", children: [new TextRun(project.name)] }));\n    projSection.push(new Paragraph({ style: "ProjectTagline", children: [new TextRun(project.tagline)] }));\n    projSection.push(new Paragraph({\n        children: [\n            new TextRun({ text: "Stack:  ", style: "ProjectStackLabel" }),\n            new TextRun({ text: project.stack.join(", "), style: "ProjectStack" })\n        ]\n    }));\n    project.bullets.forEach(bullet => {\n        projSection.push(new Paragraph({\n            style: `proj-${index}`, // Use specific numbering reference per project\n            children: [new TextRun(bullet)]\n        }));\n    });\n     if (index < payload.projects.length - 1) {\n        projSection.push(new Paragraph({ // Add spacing before next entry\n            style: "Normal",\n            spacing: { after: 160 },\n            children: []\n        }));\n    }\n});\ndoc.addSection({ children: projSection });\n\n// Education Section\nconst educationSection = [new Paragraph({ style: "Heading1", children: [new TextRun("EDUCATION")] })];\neducationSection.push(new Paragraph({\n    style: "Normal", // Using default body style for education\n    children: [\n        new TextRun("M.Sc. in Computer Science, University of Example, 2020"),\n        new TextRun({ text: "\\nB.Sc. in Software Engineering, Another University, 2018"}),\n    ]\n}));\ndoc.addSection({ children: educationSection });\n\n\n// ---OUTPUT---\nconst output_path = "/home/user/output/resumes/rohit_sharma_resume.docx";\nPacker.toBuffer(doc).then(buffer => {\n    fs.writeFileSync(output_path, buffer);\n    console.log("Resume written to " + output_path);\n});\n'}

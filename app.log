n({ text: "  |  ",           size: 18, font: "Arial", color: "AAAAAA" }),\n          new TextRun({ text: profile.location,  size: 18, font: "Arial", color: "1F3864" }),\n        ]\n      }),\n      new Paragraph({\n        heading: HeadingLevel.HEADING_1,\n        children: [new TextRun({ text: "PROFESSIONAL SUMMARY", font: "Arial" })]\n      }),\n      new Paragraph({\n        spacing: { after: 120, line: 260 },\n        children: [new TextRun({ text: payloadData.summary, size: 20, font: "Arial", color: "000000" })]\n      }),\n      new Paragraph({\n        heading: HeadingLevel.HEADING_1,\n        children: [new TextRun({ text: "CORE SKILLS", font: "Arial" })]\n      }),\n      ...(() => {\n        const SKILLS_PER_ROW = 5;\n        const TAB1 = 2088; const TAB2 = 4176; const TAB3 = 6264; const TAB4 = 8352;\n        const rows = [];\n        for (let i = 0; i < payloadData.skills.length; i += SKILLS_PER_ROW) {\n          const s = payloadData.skills;\n          const children = [];\n          children.push(new TextRun({ text: "\\u2022  " + (s[i] || ""), size: 19, font: "Arial", color: "222222" }));\n          for (let j = 1; j < SKILLS_PER_ROW; j++) {\n            if (s[i + j] !== undefined) children.push(new TextRun({ text: "\\t\\u2022  " + s[i + j], size: 19, font: "Arial", color: "222222" }));\n          }\n          rows.push(new Paragraph({\n            tabStops: [{ type: TabStopType.LEFT, position: TAB1 }, { type: TabStopType.LEFT, position: TAB2 }, { type: TabStopType.LEFT, position: TAB3 }, { type: TabStopType.LEFT, position: TAB4 }],\n            spacing: { after: 40 },\n            children\n          }));\n        }\n        return rows;\n      })(),\n      new Paragraph({\n        heading: HeadingLevel.HEADING_1,\n        children: [new TextRun({ text: "CORE TOOLS", font: "Arial" })]\n      }),\n      ...(() => {\n        const TOOLS_PER_ROW = 6;\n        const TAB1 = 1740; const TAB2 = 3480; const TAB3 = 5220; const TAB4 = 6960; const TAB5 = 8700;\n        const rows = [];\n        for (let i = 0; i < payloadData.technologies.length; i += TOOLS_PER_ROW) {\n          const t = payloadData.technologies;\n          const children = [];\n          children.push(new TextRun({ text: "\\u2022  " + (t[i] || ""), size: 19, font: "Arial", color: "222222" }));\n          for (let j = 1; j < TOOLS_PER_ROW; j++) {\n            if (t[i + j] !== undefined) children.push(new TextRun({ text: "\\t\\u2022  " + t[i + j], size: 19, font: "Arial", color: "222222" }));\n          }\n          rows.push(new Paragraph({\n            tabStops: [{ type: TabStopType.LEFT, position: TAB1 }, { type: TabStopType.LEFT, position: TAB2 }, { type: TabStopType.LEFT, position: TAB3 }, { type: TabStopType.LEFT, position: TAB4 }, { type: TabStopType.LEFT, position: TAB5 }],\n            spacing: { after: 40 },\n            children\n          }));\n        }\n        return rows;\n      })(),\n      new Paragraph({\n        heading: HeadingLevel.HEADING_1,\n        children: [new TextRun({ text: "PROFESSIONAL EXPERIENCE", font: "Arial" })]\n      }),\n      ...payloadData.experience.flatMap((entry, ei) => [\n        new Paragraph({\n          alignment: AlignmentType.LEFT,\n          tabStops: [{ type: TabStopType.RIGHT, position: 9360 }],\n          spacing: { before: 100, after: 0 },\n          children: [\n            new TextRun({ text: entry.role_title, bold: true, size: 21, font: "Arial", color: "1F3864" }),\n            new TextRun({ text: "\\t" + entry.date_range, italics: true, size: 19, font: "Arial", color: "666666" })\n          ]\n        }),\n        new Paragraph({\n          spacing: { before: 0, after: 80 },\n          children: [new TextRun({ text: entry.organisation, italics: true, size: 19, font: "Arial", color: "888888" })]\n        }),\n        ...entry.bullets.map((bullet, bi) => new Paragraph({\n          numbering: { reference: "exp-bullets", level: 0 },\n          spacing: { after: bi === entry.bullets.length - 1 ? 160 : 40
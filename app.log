tType.CENTER, spacing: { before: 0, after: 0 } }\n        },\n        {\n             id: "Divider", name: "Divider",\n             paragraph: { border: { bottom: { style: BorderStyle.SINGLE, size: 8, color: "1F3864", space: 4 } }, spacing: { before: 0, after: 120 }}\n        }\n    ]\n};\n\n// ---CONSTANTS---\nconst CONTENT_WIDTH = 10440; // 12240 (US Letter) - 900 (left margin) - 900 (right margin)\nconst DOCX_MARGIN = 900; // Margins for the page\nconst DOCX_PAGE_WIDTH = 12240;\nconst DOCX_PAGE_HEIGHT = 15840;\n\n// ---DOCUMENT STRUCTURE---\nconst doc = new Document({\n    styles: styles,\n    sections: [{\n        properties: {\n            page: {\n                size: { width: DOCX_PAGE_WIDTH, height: DOCX_PAGE_HEIGHT, orientation: PageOrientation.PORTRAIT },\n                margin: { top: DOCX_MARGIN, bottom: DOCX_MARGIN, left: DOCX_MARGIN, right: DOCX_MARGIN }\n            }\n        },\n        headers: {\n            default: new Header({ children: [\n                new Paragraph({ style: "NameStyle", children: [new TextRun("ROHIT SHARMA")] }),\n                new Paragraph({ style: "ContactInfo", children: [new TextRun("rohit.sharma@email.com | github.com/rohit-sharma | linkedin.com/in/rohit-sharma | Nigeria")] }),\n                new Paragraph({ style: "Divider", children: [] })\n            ]})\n        },\n        footers: {\n            default: new Footer({ children: [\n                new Paragraph({\n                    style: "ContactInfo",\n                    children: [\n                        new TextRun("Page "),\n                        new TextRun({ children: [PageNumber.CURRENT] })\n                    ],\n                    alignment: AlignmentType.CENTER\n                })\n            ]})\n        },\n        children: [] // Content will be added dynamically\n    }]\n});\n\n// ---NUMBERING CONFIG---\ndoc.Numbering.config.push(\n    { reference: "exp-bullets", levels: [{ level: 0, format: LevelFormat.BULLET, text: "•", alignment:
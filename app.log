ge.",\n    tech: ["LLMs", "Python"],\n    highlights: ["AI-powered medical assistant", "Immediate first aid guidance", "LLM-based natural language processing"]\n  },\n  {\n    name: "medai",\n    description: "Conversational AI assistant for first aid guidance and medical information extraction, built with Flask and Google Gemini.",\n    tech: ["AI", "Flask", "Google Gemini", "Python"],\n    highlights: ["Web application for first aid guidance", "Medical information extraction", "Conversational AI assistant"]\n  }\n];\n\nconst education = "Degree, Institution, Year"; // Placeholder\n\n// --- Document Creation ---\nconst doc = new Document({\n  styles: {\n    default: { document: { run: { font: "Arial", size: 24 } } }, // 12pt default\n    paragraphStyles: [\n      { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true,\n        run: { size: 32, bold: true, font: "Arial" },\n        paragraph: { spacing: { before: 240, after: 240 }, outlineLevel: 0 } },\n      { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true,\n        run: { size: 28, bold: true, font: "Arial" },\n        paragraph: { spacing: { before: 180, after: 180 }, outlineLevel: 1 } },\n      { id: "ContactLine", name: "Contact Line", basedOn: "Normal", run: { font: "Arial", size: 20 } }, // Smaller font for contact info\n      { id: "Header", name: "Header", basedOn: "Normal", run: { font: "Arial", size: 22, color: "555555" } }, // Gray for header\n      { id: "Footer", name: "Footer", basedOn: "Normal", run: { font: "Arial", size: 20, color: "888888" } }  // Gray for footer\n    ]\n  },\n  numbering: {\n    config: [\n      { reference: "bulletList",\n        levels: [{ level: 0, format: LevelFormat.BULLET, text: "•", alignment: AlignmentType.LEFT,\n          style: { paragraph: { indent: { left: 720, hanging: 360 } } } }]\n      }\n    ]\n  },\n  sections: [{\n    properties: {\n      page: {\n        size: { width: US_LETTER_WIDTH, height: US_LETTER_HEIGHT, orientation: PageOrientation.PORTRAIT },\n        margin: { top: MARGIN_DXA, right: MARGIN_DXA, bottom: MARGIN_DXA, left: MARGIN_DXA }\n      }\n    },\n    headers: {\n      default: new Header({\n        children: [\n          new Paragraph({\n            alignment: AlignmentType.RIGHT,\n            children: [\n              new TextRun({ text: current_date, style: "Header" })\n            ],\n            tabStops: [\n              { type: TabStopType.RIGHT, position: TabStopPosition.MAX }\n            ]\n          })\n        ]\n      })\n    },\n    footers: {\n      default: new Footer({\n        children: [\n          new Paragraph({\n            alignment: AlignmentType.CENTER,\n            children: [\n              new TextRun({ text: "Page ", style: "Footer" }),\n              new TextRun({ children: [PageNumber.CURRENT], style: "Footer" })\n            ],\n            style: "Footer"\n          })\n        ]\n      })\n    },\n    children: [\n      // --- Header ---\n      new Paragraph({\n        alignment: AlignmentType.CENTER,\n        spacing: { after: 200 },\n        children: [\n          new TextRun({ text: candidate_name_full, size: 48, bold: true, font: "Arial" }),\n        ]\n      }),\n      new Paragraph({\n        alignment: AlignmentType.CENTER,\n        spacing: { before: 0, after: 400 },\n        style: "ContactLine",\n        children: [\n          new TextRun(`${candidate_email} | ${candidate_github} | ${candidate_linkedin}`),\n        ]\n      }),\n\n      // --- Professional Summary ---\n      new Paragraph({ heading: HeadingLevel.HEADING_1, children: [new TextRun("Professional Summary")] }),\n      new Paragraph({\n        style: "Normal",\n        children: [new TextRun(job_description_summary)]\n      }),\n\n      // --- Technical Skills ---\n      new Paragraph({ heading: HeadingLevel.HEADING_1, children: [new TextRun("Technical Skills")] }),\n      ...skills.map(skill => new Paragraph({\n        numbering: { reference: "bulletList", level: 0 },\n        children: [new TextRun(skill)]\n      })),\n\n      // --- Technologies & Tools ---\n      new Paragraph({ heading: HeadingLevel.HEADING_1, children: [new TextRun("Technologies & Tools")] }),\n      ...(technologies.languages || []).map(tech => new Paragraph({ numbering: { reference: "bulletList", level: 0 }, children: [new TextRun(tech)] })),\n      ...(technologies.frameworks || []).map(tech => new Paragraph({ numbering: { reference: "bulletList", level: 0 }, children: [new TextRun(tech)] })),\n      ...(technologies.tools || []).map(tech => new Paragraph({ numbering: { reference: "bulletList", level: 0 }, children: [new TextRun(tech)] })),\n      ...(technologies.platforms || []).map(tech => new Paragraph({ numbering: { reference: "bulletList", level: 0 }, children: [new TextRun(tech)] })),\n\n      // --- Project Experience ---\n      new Paragraph({ heading: HeadingLevel.HEADING_1, children: [new TextRun("Project Experience")] }),\n      ...projects.flatMap(project => [\n        new Paragraph({ heading: HeadingLevel.HEADING_2, children: [new TextRun(project.name)] }),\n        new Paragraph({ children: [new TextRun(project.description)] }),\n        ...project.highlights.map(highlight => new Paragraph({\n          numbering: { reference: "bulletList", level: 0 },\n          children: [new TextRun(highlight)]\n        })),\n        new Paragraph({ children: [new TextRun(`Technologies: ${project.tech.join(\', \')}`)] }),\n        new Paragraph({}), // Add some space between projects\n      ]),\n\n      // --- Education ---\n      new Paragraph({ heading: HeadingLevel.HEADING_1, children: [new TextRun("Education")] }),\n      new Paragraph({ children: [new TextRun(education)] }),\n    ]\n  }]\n});\n\n// --- Output ---\nconst output_path = "output/resumes/machine_learning_engineer_resume.docx"; // This path will be dynamically set by generate_resume_js\n\nPacker.toBuffer(doc).then(buf => {\n  fs.writeFileSync(out